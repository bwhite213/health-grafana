  "description": "Oura Ring native metrics dashboard. Queries the raw Oura* measurements. Every timeseries panel includes a 14-day personal rolling baseline ('Your typical'). Panels marked with '_normalRangeMetric' also get a green/yellow/red population band that the fetcher stamps in on startup from USER_AGE / USER_SEX env vars (see src/garmin_grafana/normal_ranges.py).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "influxdb",
        "uid": "garmin_influxdb"
      },
      "description": "AI-generated wellness summary updated each fetch cycle. Requires ANTHROPIC_API_KEY in env.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 200,
      "options": {
        "content": "{{fix summary}}",
        "defaultContent": "<p><em>Waiting for AI summary. Set ANTHROPIC_API_KEY and wait for a fetch cycle.</em></p>",
        "editor": {
          "format": "auto",
          "language": "markdown"
        },
        "externalStyles": [],
        "helpers": "handlebars.registerHelper(\"fix\",function(s){return new handlebars.SafeString((s||\"\").split(\"\\\\n\").join(\"\"));});",
        "renderMode": "everyRow",
        "status": "never",
        "styles": "",
        "wrap": true
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "garmin_influxdb"
          },
          "query": "SELECT last(\"summary\") AS \"summary\" FROM \"AIHealthSummary\" WHERE \"dashboard\" = 'oura_health'",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "table"
        }
      ],
      "title": "AI Wellness Summary",
      "type": "marcusolsson-dynamictext-panel"
    },
