            "type": "influxdb",
            "uid": "garmin_influxdb"
          },
          "query": "SELECT mean(\"rem_sleep_duration\") / 3600 FROM \"OuraSleep\" WHERE $timeFilter GROUP BY time(1d) fill(null)",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        },
