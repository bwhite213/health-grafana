          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "alias": "$tag_Source",
          "datasource": {
            "type": "influxdb",
            "uid": "garmin_influxdb"
          },
          "groupBy": [
            {
              "params": [
                "1d"
              ],
              "type": "time"
            },
            {
              "params": [
