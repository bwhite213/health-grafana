  "description": "Cross-source view of health data from Garmin, Oura (and future Apple Watch). Shows per-source lines, a cross-source average, and a discrepancy panel highlighting where sources disagree. Every timeseries panel also shows your 14-day rolling personal baseline ('Your typical') as a dashed gray line; metrics with clinical norms (sleep duration, RHR, steps) get a green/yellow/red population band tuned for a 35M (see config/normal_ranges.yaml).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Sleep",
      "type": "row"
    },
    {
      "datasource": {"type": "influxdb", "uid": "garmin_influxdb"},
      "description": "Nightly sleep duration by source. Toggle $source to filter. Green band = CDC/NSF adult recommendation (7-9h). Dashed gray line = your 14-day rolling typical across all sources.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "hours",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 6,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "area"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 6},
            {"color": "green", "value": 7},
            {"color": "yellow", "value": 9},
            {"color": "red", "value": 10}
          ]},
          "unit": "h"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "Your typical.*"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"dash": [8, 4], "fill": "dash"}},
              {"id": "custom.lineWidth", "value": 1},
              {"id": "custom.fillOpacity", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "rgba(200,200,200,0.9)"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "min", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "alias": "$tag_Source",
          "datasource": {"type": "influxdb", "uid": "garmin_influxdb"},
          "groupBy": [
            {"params": ["1d"], "type": "time"},
            {"params": ["Source"], "type": "tag"},
            {"params": ["null"], "type": "fill"}
          ],
          "measurement": "UnifiedSleep",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "SELECT mean(\"duration_s\") / 3600 FROM \"UnifiedSleep\" WHERE (\"Source\" =~ /^$source$/) AND $timeFilter GROUP BY time(1d), \"Source\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series",
          "select": [[{"params": ["duration_s"], "type": "field"}, {"params": [], "type": "mean"}]],
          "tags": []
        },
        {
          "alias": "Mean (all sources)",
          "datasource": {"type": "influxdb", "uid": "garmin_influxdb"},
          "hide": false,
          "query": "SELECT mean(\"duration_s\") / 3600 FROM \"UnifiedSleep\" WHERE $timeFilter GROUP BY time(1d) fill(null)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        },
        {
          "alias": "Your typical (14d)",
          "datasource": {"type": "influxdb", "uid": "garmin_influxdb"},
          "query": "SELECT moving_average(mean(\"duration_s\"), 14) / 3600 FROM \"UnifiedSleep\" WHERE $timeFilter GROUP BY time(1d) fill(null)",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        }
      ],
      "title": "Sleep duration by source",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "influxdb", "uid": "garmin_influxdb"},
      "description": "HRV averaged over each night's sleep, per source. Dashed gray line = your 14-day rolling typical. No population band — HRV is too individual for one to be meaningful.",
