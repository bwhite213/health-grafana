          ],
          "measurement": "UnifiedSleep",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "SELECT mean(\"duration_s\") / 3600 FROM \"UnifiedSleep\" WHERE (\"Source\" =~ /^$source$/) AND $timeFilter GROUP BY time(1d), \"Source\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series",
          "select": [
            [
              {
                "params": [
                  "duration_s"
                ],
                "type": "field"
              },
              {
                "params": [],
                "type": "mean"
              }
            ]
