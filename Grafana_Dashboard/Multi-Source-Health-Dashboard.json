          "refId": "B",
          "resultFormat": "time_series"
        },
        {
          "alias": "Your typical (14d)",
          "datasource": {
            "type": "influxdb",
            "uid": "garmin_influxdb"
          },
          "query": "SELECT moving_average(mean(\"duration_s\"), 14) / 3600 FROM \"UnifiedSleep\" WHERE $timeFilter GROUP BY time(1d) fill(null)",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        }
      ],
      "title": "Sleep duration by source",
      "type": "timeseries"
    },
