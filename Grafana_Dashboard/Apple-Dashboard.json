    {
      "id": 7,
      "title": "Sleep duration",
      "type": "timeseries",
      "datasource": {
        "type": "influxdb",
        "uid": "P951FEA4DE68E13C5"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "P951FEA4DE68E13C5"
          },
          "query": "SELECT mean(\"duration_s\") / 3600 FROM \"UnifiedSleep\" WHERE \"Source\" = 'Apple' AND $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A",
          "rawQuery": true,
          "resultFormat": "time_series",
          "alias": "A"
