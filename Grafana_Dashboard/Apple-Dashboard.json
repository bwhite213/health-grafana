                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              },
              {
                "color": "yellow",
                "value": 9
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
