# health-grafana local configuration — template
#
# Copy this file to `override-default-vars.env` (git-ignored) and fill in
# your real values. NEVER commit the populated file, and NEVER paste its
# contents into chat, issue trackers, Slack, etc.
#
#     cp override-default-vars.env.example override-default-vars.env
#     nano override-default-vars.env        # fill in values
#     chmod 600 override-default-vars.env   # lock permissions
#
# The bundled scripts/check_secrets.py scanner and the CI workflow both
# guard against accidental commits of this file with real values populated.

############################################################################
# Garmin Connect
############################################################################

# Your Garmin Connect email address.
GARMINCONNECT_EMAIL=

# Base64-encoded Garmin Connect password. Encode with:
#   echo -n 'your-real-password' | base64
# DO NOT store the plaintext password here.
GARMINCONNECT_BASE64_PASSWORD=

# Set to True only if you use a mainland-China Garmin account.
GARMINCONNECT_IS_CN=False

############################################################################
# Oura Ring
############################################################################

# Personal Access Token from https://cloud.ouraring.com/personal-access-tokens
# Leave blank (or set OURA_ENABLED=False) to disable Oura fetching.
OURA_PERSONAL_ACCESS_TOKEN=

# Explicit on/off switch. Defaults to True when a token is set.
OURA_ENABLED=True

############################################################################
# Cross-source analytics layer
############################################################################

# Write Unified* mirror measurements + SourceDiscrepancy. Leave on unless
# you have a reason not to.
ENABLE_UNIFIED_MEASUREMENTS=True

# How many days back the discrepancy detector recomputes each cycle.
DISCREPANCY_LOOKBACK_DAYS=14

# Which Garmin subsystems to fetch. The list below drops the noisy
# `lifestyle` selector and enables training_readiness (better cross-source
# readiness comparison with Oura) and training_status.
FETCH_SELECTION=daily_avg,sleep,steps,heartrate,stress,breathing,hrv,fitness_age,vo2,activity,race_prediction,body_composition,training_readiness,training_status

############################################################################
# User profile (drives the normal-range bands on the dashboards)
############################################################################
#
# Stamped into the Grafana dashboards at fetcher startup by
# src/garmin_grafana/normal_ranges.py. Leave blank to skip stamping.

USER_AGE=
USER_SEX=
# USER_HEIGHT_CM=        # optional, reserved
# USER_WEIGHT_KG=        # optional, reserved

############################################################################
# Dead-man's switch (optional but strongly recommended)
############################################################################
#
# Full URL of a https://healthchecks.io check (or any self-hosted equivalent
# that follows the same `$URL`, `$URL/start`, `$URL/fail` convention). The
# orchestrator pings /start at cycle begin, the bare URL on success, and
# /fail on error. If no ping arrives within the check's grace window you
# get an email / Slack / push notification — useful when traveling.
#
# See docs/auto-deploy.md for setup instructions.

HEALTHCHECK_PING_URL=

############################################################################
# Housekeeping
############################################################################

# TZ identifier for your local timezone (e.g. America/New_York, Europe/Berlin).
USER_TIMEZONE=

# Default log level for the fetcher. Set to DEBUG for troubleshooting.
LOG_LEVEL=INFO

# How often the orchestrator runs a cycle. Oura syncs 1–2x/day, Garmin
# hourly-ish; anything faster than 15 min mostly burns API quota on
# empty cycles. Default in garmin_fetch.py is 300 (5 min) for upstream
# compatibility — 900 (15 min) is the recommended override. Keep the
# healthchecks.io check period/grace aligned (15 min / 30 min).
UPDATE_INTERVAL_SECONDS=900

############################################################################
# Grafana admin credentials
############################################################################
#
# Used on first-boot to seed the admin user. After that, the live password
# is stored inside /var/lib/grafana/grafana.db; change it at any time with:
#   docker exec grafana grafana cli admin reset-admin-password <new>
# Keep this env value in sync with the live DB so a volume wipe restores
# the same credentials instead of falling back to admin/admin.

GF_SECURITY_ADMIN_USER=admin
# NOTE: escape any literal `$` in the password as `$$` — docker compose
# interpolates env_file values, so `abc$xyz` arrives at Grafana as `abc`.
# Write `abc$$xyz` here to get the intended `abc$xyz` at runtime.
GF_SECURITY_ADMIN_PASSWORD=

############################################################################
# AI summary webhook (click-to-regenerate link in Grafana)
############################################################################
#
# The fetcher exposes an HTTP endpoint on :8765 that force-regenerates
# the AI wellness summaries. It's on by default; disable entirely with
# SUMMARY_WEBHOOK_DISABLED=true. Rate limit caps callers to 1 request
# per minute per container so accidental F5-mashing can't rack up
# Anthropic API cost.
#
# Security model: the port is only reachable via the same LAN/VPN
# boundary that already fronts Grafana. No auth by default. If you
# need stronger gating (e.g. the port is internet-exposed), set
# SUMMARY_WEBHOOK_TOKEN; then append ?token=<value> to the dashboard
# link URLs in Grafana_Dashboard/*.json.
# SUMMARY_WEBHOOK_TOKEN=
# SUMMARY_WEBHOOK_DISABLED=

############################################################################
# Optional one-off bulk backfill (remove both lines once finished)
############################################################################

# MANUAL_START_DATE=2026-01-01
# MANUAL_END_DATE=2026-04-15
